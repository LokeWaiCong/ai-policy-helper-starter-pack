# ── LLM ──────────────────────────────────────────────────────────────────────
# stub = fully offline (no key needed)
# openrouter = uses OpenRouter API (set OPENROUTER_API_KEY below)
LLM_PROVIDER=stub
OPENROUTER_API_KEY=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  
LLM_MODEL=openai/gpt-4o-mini
OLLAMA_HOST=http://ollama:11434

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=local-384

# ── Vector store ──────────────────────────────────────────────────────────────
# qdrant = Qdrant via Docker (default)
# memory = in-process, resets on restart
VECTOR_STORE=qdrant
COLLECTION_NAME=policy_helper

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=700
CHUNK_OVERLAP=80

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE=http://localhost:8000
